# Copy this file to backend/.env.local and set your ChatGPT API key plus optional overrides
CHATGPT_API_KEY=sk-your-openai-key
OPENAI_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
RAG_CHUNK_SIZE=800
RAG_CHUNK_OVERLAP=200
RAG_MAX_FILE_BYTES=20000000
PORT=4000
# Database connectivity (Postgres)
DB_HOST=localhost
DB_PORT=8002
DB_USER=db_admin
DB_PASSWORD=db_password
DB_NAME=marketing_tools
# Optional: override the above with a single connection string
# DATABASE_URL=postgresql://db_admin:db_password@localhost:8002/marketing_tools
# Optional: comma separated origins for CORS, e.g. http://localhost:3005
# CORS_ORIGINS=
